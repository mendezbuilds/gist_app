{
  "expo": {
    "name": "Gist",
    "slug": "gist",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "gist",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gist.app",
      "infoPlist": {
        "NSContactsUsageDescription": "Gist uses your contacts to help you find friends who are already on the app. Your phone numbers are hashed on your device and never stored on our servers.",
        "NSPhotoLibraryUsageDescription": "Gist needs access to your photos to set your profile picture and share images in chats.",
        "NSCameraUsageDescription": "Gist needs camera access to take photos for your profile or to share in chats.",
        "NSMicrophoneUsageDescription": "Gist uses your microphone for voice calls and voice messages."
      }
    },
    "android": {
      "bundleIdentifier": "com.gist.app",
      "package": "com.gist.app",
      "adaptiveIcon": {
        "backgroundColor": "#1B2A6B",
        "foregroundImage": "./assets/adaptive-icon.png"
      },
      "permissions": [
        "android.permission.READ_CONTACTS",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F7F1E3",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "dark": {
            "backgroundColor": "#0E1224",
            "image": "./assets/splash-icon-dark.png"
          }
        }
      ],
      "expo-status-bar",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#E8552F"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    }
  }
}
